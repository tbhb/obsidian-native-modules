{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-v-in-tag": false,
  "include-component-in-tag": true,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "prerelease": true,
  "prerelease-type": "beta",
  "versioning": "prerelease",
  "packages": {
    "packages/catalog": {
      "package-name": "@obsidian-native-modules/catalog",
      "component": "catalog",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/loader": {
      "package-name": "@obsidian-native-modules/loader",
      "component": "loader",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/builder": {
      "package-name": "@obsidian-native-modules/builder",
      "component": "builder",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/watcher": {
      "package-name": "@obsidian-native-modules/watcher",
      "component": "watcher",
      "changelog-path": "CHANGELOG.md"
    }
  },
  "plugins": ["node-workspace"]
}

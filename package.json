{
  "name": "obsidian-native-modules",
  "version": "0.0.0",
  "private": true,
  "description": "Prebuilt Node native modules for Obsidian plugins, with a runtime loader and build-time tooling.",
  "license": "MIT",
  "author": "Tony Burns <tony@tonyburns.net>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tbhb/obsidian-native-modules.git"
  },
  "bugs": {
    "url": "https://github.com/tbhb/obsidian-native-modules/issues"
  },
  "homepage": "https://obsidian-native-modules.dev",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.22.0 <23",
    "pnpm": ">=10"
  },
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "check": "biome check . && eslint .",
    "check:fix": "biome check --write . && eslint --fix .",
    "depcruise:graph": "depcruise packages/*/src packages/*/test --include-only '^packages/' --output-type mermaid --output-to dependency-graph.mmd",
    "format": "biome format --write .",
    "format:markdown": "rumdl fmt .",
    "lint": "biome lint . && eslint .",
    "lint:actions": "actionlint",
    "lint:all": "pnpm run lint && pnpm run lint:deps && pnpm run lint:knip && pnpm run lint:markdown && pnpm run lint:yaml && pnpm run lint:spelling && pnpm run lint:actions && pnpm run lint:prose",
    "lint:deps": "depcruise packages/*/src packages/*/test",
    "lint:knip": "knip",
    "lint:markdown": "rumdl check .",
    "lint:markdown:fix": "rumdl check --fix .",
    "lint:prose": "vale --glob='!{.vale/**,node_modules/**,coverage/**,dist/**,tmp/**,**/CHANGELOG.md}' .",
    "lint:spelling": "cspell --no-progress --no-summary --gitignore .",
    "lint:staged": "nano-staged",
    "lint:yaml": "yamllint --strict .",
    "vale:sync": "vale sync"
  },
  "nano-staged": {
    "*.{ts,mts,tsx,js,mjs,cjs,jsx,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ],
    "packages/*/src/**/*.{ts,mts,tsx}": [
      "eslint --fix --no-warn-ignored"
    ],
    "*.md": [
      "rumdl check --fix",
      "vale"
    ],
    "*.{yml,yaml}": "yamllint --strict",
    ".github/workflows/*.{yml,yaml}": "actionlint",
    "*.{ts,mts,tsx,js,mjs,cjs,jsx,json,jsonc,md,yml,yaml,css,html}": "cspell --no-progress --no-summary --no-must-find-files"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@types/node": "^22.19.0",
    "@vitest/coverage-v8": "^4.1.4",
    "cspell": "^9.7.0",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^9.30.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "knip": "^6.6.2",
    "nano-staged": "^1.0.2",
    "tslib": "^2.8.1",
    "turbo": "^2.3.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.4"
  }
}

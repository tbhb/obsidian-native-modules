# editors
.vscode
.idea
*.iml

# dependencies (pnpm-lock.yaml is committed)
node_modules

# Vale: ignore downloaded style packages, keep the project-specific style
# and vocabulary (these live under .vale/obsidian-native-modules/ and
# .vale/config/vocabularies/obsidian-native-modules/).
/.vale/*
!/.vale/obsidian-native-modules/
!/.vale/config/
/.vale/config/*
!/.vale/config/vocabularies/
/.vale/config/vocabularies/*
!/.vale/config/vocabularies/obsidian-native-modules/

# build output (published to npm, not committed).
/dist/
packages/*/dist/

# TypeScript incremental build cache
*.tsbuildinfo

# Turborepo local cache
.turbo/
packages/*/.turbo/

# test output
coverage
/test-results
packages/*/coverage/

# logs
*.log
.pnpm-debug.log*

# husky wrappers — the hook files in .husky/ are committed, but the
# _/ subdirectory is regenerated by `pnpm install` via the prepare script.
.husky/_/

# dependency-cruiser: on-demand mermaid graph output
/dependency-graph.mmd

# jscpd: on-demand report output (written when reporters include html, json, etc.)
/report/

# stryker: html report and sandbox tmp dir. The incremental report file
# (packages/*/reports/stryker-incremental.json) is regenerated per run; CI
# restores it from cache, locally it's fine to discard.
packages/*/reports/
packages/*/.stryker-tmp/

# scratch space
/tmp/

# os
.DS_Store

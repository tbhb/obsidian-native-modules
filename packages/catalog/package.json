{
  "name": "@obsidian-native-modules/catalog",
  "version": "0.1.1-beta.3",
  "description": "Shared platform matrix, asset-naming, and type definitions for @obsidian-native-modules/*.",
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "electron",
    "native-modules"
  ],
  "license": "MIT",
  "author": "Tony Burns <tony@tonyburns.net>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tbhb/obsidian-native-modules.git",
    "directory": "packages/catalog"
  },
  "bugs": {
    "url": "https://github.com/tbhb/obsidian-native-modules/issues"
  },
  "homepage": "https://obsidian-native-modules.dev",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project=unit",
    "test:integration": "vitest run --project=integration --passWithNoTests",
    "test:property": "vitest run --project=property --passWithNoTests",
    "test:coverage": "vitest run --project=unit --coverage",
    "test:mutation": "stryker run"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.4.0",
    "fast-check": "^4.7.0"
  }
}
